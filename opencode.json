{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "blender-mcp": {
      "type": "local",
      "command": ["uvx", "--python", "3.11", "blender-mcp"],
      "enabled": true,
      "environment": {
        "BLENDER_HOST": "localhost",
        "BLENDER_PORT": "9876",
        "DISABLE_TELEMETRY": "true",
        "UV_PYTHON_PREFERENCE": "only-managed"
      }
    }
  },
  "skills": {
    "paths": [
      ".cursor/skills"
    ]
  },
  "agent": {
    "default": {
      "description": "Orchestrator — teamledare som planerar, delegerar till specialister (blender-artist, ios-engineer, film-producer, hantverkare) och följer upp"
    }
  }
}
